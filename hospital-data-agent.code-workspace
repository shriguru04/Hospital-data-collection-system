{
  "folders": [
    { "path": "." }
  ],
  "settings": {
    "python.defaultInterpreterPath": "${workspaceFolder}/venv/bin/python",
    "python.terminal.activateEnvironment": true,
    "files.exclude": {
      "**/__pycache__": true,
      "**/*.pyc": true
    }
  },
  "launch": {
    "version": "0.2.0",
    "configurations": [
      {
        "name": "Run Hospital Data Agent (Flask)",
        "type": "debugpy",
        "request": "launch",
        "module": "backend.app",
        "console": "integratedTerminal",
        "envFile": "${workspaceFolder}/.env",
        "cwd": "${workspaceFolder}"
      }
    ]
  }
}
