# ============================================================
# Hospital Data Collection Agent — environment configuration
# ============================================================
# Copy this file to .env and set the values you have.
# The app runs perfectly with ZERO values set (mock data mode).

# --- Server -----------------------------------------------------------
HOST=127.0.0.1
PORT=5000
DEBUG=true

# --- Data source mode -------------------------------------------------
#
#  mock     → sample_data/mock_hospitals.json   (default, no internet)
#  live     → RECOMMENDED for real data:
#              1. Google Places API  (if key is set below)
#              2. OpenStreetMap / Overpass  (free, no key needed)
#              3. JustDial scraper  (India)
#              4. Yelp scraper  (USA / global)
#  osm      → OpenStreetMap / Overpass only  (free, global, no key)
#  places   → Google Places API only  (requires key below)
#
DATA_SOURCE_MODE=live

# --- Google Places API key (optional but strongly recommended) ---------
# Get one free at: https://console.cloud.google.com/
# Enable "Places API" in the project.
# Without this key, DATA_SOURCE_MODE=live still works via OSM + scrapers.
GOOGLE_PLACES_API_KEY=

# --- Optional LLM-assisted chat parsing --------------------------------
# If set, the Planner uses Claude to understand your search request,
# which handles messier phrasing better than the built-in keyword parser.
# Requires internet + Anthropic account: https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Rate limiting / scraping etiquette --------------------------------
SOURCE_REQUEST_DELAY_SECONDS=1.0
MAX_RECORDS_HARD_CAP=200
